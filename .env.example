# =============================================================================
# ERA Innovations — API environment variables
# Copy to `.env` locally; set these in the DirectAdmin Node.js panel for prod.
# =============================================================================

# Server
PORT=3000
NODE_ENV=production

# Where to read markdown posts from. Absolute path on the server.
# DirectAdmin example:
#   /home/<account>/domains/erainnovations.ro/email-api/posts
POSTS_DIR=./posts

# SMTP (use one of your @erainnovations.ro mailboxes from DirectAdmin Email Accounts)
SMTP_HOST=mail.erainnovations.ro
SMTP_PORT=587
SMTP_USER=hello@erainnovations.ro
SMTP_PASS=your-mailbox-password

# Where contact submissions are delivered
TO_EMAIL=hello@erainnovations.ro
